{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "../.tmp/preset-previews",
    "rootDir": "..",
    "incremental": false,
    "jsx": "preserve"
  },
  "include": [
    "../scripts/generate-preset-previews.ts",
    "../src/lib/openai/**/*.ts",
    "../src/lib/creatives/**/*.ts",
    "../src/lib/whatsapp/**/*.ts"
  ],
  "exclude": ["../**/*.test.ts", "../**/*.test.tsx"]
}

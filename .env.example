# Local development default. In Vercel, set this to the final public domain used in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=LeadHealth
LEGAL_CONTACT_EMAIL=
NEXT_PUBLIC_LEGAL_EMAIL=

# Core obrigatorio em producao
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: operacoes admin, webhooks e MCP Supabase local
# O MCP Supabase usa apenas estas duas variaveis no ambiente local/server.
# Nunca exponha essas chaves no browser.
SUPABASE_SERVICE_ROLE_KEY=
INTEGRATIONS_SECRET_KEY=

# Opcional: IA
# A IA do produto usa chaves conectadas por organizacao; OPENAI_MODEL ajusta o padrao do servidor.
OPENAI_MODEL=gpt-4o-mini

# Opcional: pagamentos
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# Opcional: Meta
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_REDIRECT_URI=
META_GRAPH_API_VERSION=v22.0

DATABASE_URL=

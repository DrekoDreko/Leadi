# Template seguro de ambiente para desenvolvimento local e configuracao na Vercel.
# Nunca coloque valores reais de producao neste arquivo nem em `.env.production` versionado.
# Variaveis `NEXT_PUBLIC_*` podem ir para o client; todas as demais devem permanecer server-side.

# Publicas: branding e URL canonica.
# In Vercel, set this to the final public domain used in production.
# If omitted in Production, the app falls back to the deployment URL so the build can still pass.
NEXT_PUBLIC_APP_URL=https://leadi.example.com
NEXT_PUBLIC_SITE_NAME=Leadi
NEXT_PUBLIC_LEGAL_EMAIL=

# Server-only: contato juridico/operacional interno.
LEGAL_CONTACT_EMAIL=

# Publicas: configuracao base do client do Supabase.
# Core obrigatorio em producao.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: operacoes admin, webhooks e MCP Supabase local.
# O MCP Supabase usa apenas estas duas variaveis no ambiente local/server.
# Nunca exponha essas chaves no browser.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only: segredos de integracoes e cifragem.
# Core obrigatorio em producao (indispensavel para cifragem/decifragem segura de tokens de integracao Meta/OpenAI).
INTEGRATIONS_SECRET_KEY=

# Server-only: IA.
# A IA do produto usa chaves conectadas por organizacao; OPENAI_MODEL ajusta o padrao do servidor.
OPENAI_MODEL=gpt-4o-mini
# Modelo de geracao de imagem para as artes criadas com IA (default gpt-image-1).
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_API_KEY=

# Server-only: pagamentos (AbacatePay).
ABACATE_PAY_API_KEY=

# Server-only: Meta OAuth e webhook.
# Nao adicione o prefixo NEXT_PUBLIC_ a estas variaveis para nao vazar os segredos no client.
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_REDIRECT_URI=https://leadi.example.com/api/integrations/meta/callback
META_GRAPH_API_VERSION=v22.0
# Grupos de scopes habilitados no OAuth da Meta (csv).
# Default: base,webhook (base ja aprovado; webhook inscreve paginas no leadgen).
# Adicione lead_forms,ads conforme cada grupo for aprovado no App Review.
META_OAUTH_SCOPE_GROUPS=base,webhook

# Server-only: envio oficial por WhatsApp via Meta.
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_API_VERSION=v22.0

# Server-only: envio por provedor externo de WhatsApp.
WHATSAPP_EXTERNAL_SEND_URL=
WHATSAPP_EXTERNAL_API_KEY=
WHATSAPP_EXTERNAL_SENDER_ID=

# Infra local/opcional.
DATABASE_URL=

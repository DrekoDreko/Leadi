    "security:check": "vitest run src/lib/security/client-code-guard.test.ts src/lib/integrations/crypto.server.test.ts",
    "webhook:check": "node scripts/check-lead-webhook-receipt.mjs",
    "webhook:test": "node scripts/test-lead-webhook.mjs",
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",

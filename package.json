  "private": true,
  "scripts": {
    "ai:preview": "tsc -p scripts/tsconfig.ai-preview.json && node .tmp/ai-preview/scripts/ai-prompt-preview.js",
    "creatives:previews": "tsc -p scripts/tsconfig.preset-previews.json && node .tmp/preset-previews/scripts/generate-preset-previews.js",

    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.468.0",
    "motion": "^12.40.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
